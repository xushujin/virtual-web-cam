{
  "name": "virtualwebcam-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "npm run build",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.thresholds.lines=90 --coverage.thresholds.functions=90 --coverage.thresholds.branches=75 --coverage.include='src/utils/**/*.js'"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "lucide-vue-next": "^0.468.0",
    "vite": "^6.0.7",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
